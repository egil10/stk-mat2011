# Ignored project folders
.archive/
.claude/
.venv/
.vscode/
.idea/

# Data files - ignore everything in raw/processed except README
code/data/raw/*
!code/data/raw/README.md
code/data/processed/*
!code/data/processed/README.md
code/data/*.csv
!code/data/samples/

# Keep synthetic data tracked
!code/data/synthetic/
!code/data/synthetic/**

# Large/binary data formats
*.parquet
*.zip
*.gz
*.pdf
*.html

# Whitelist tracked artifacts
!code/plots/
!code/plots/**
!code/plots/**/*.pdf
!code/plots/**/*.png
!code/plots/**/*.html
!code/pdfs/
!code/pdfs/**
!code/pdfs/**/*.pdf
!code/materials/**
!code/materials/**/*.pdf
!/*.pdf

# Python
__pycache__/
*.py[cod]
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store

# Logs
*.log

# Environment / Secrets
.env
.env.local
.env.*.local
*.pem
*.key

# Model weights / Large binaries
*.pkl
*.npy
*.npz

# Temporary
*.tmp
*~